{
  "name": "formatbuddy-desktop",
  "version": "0.7.4",
  "private": true,
  "description": "FormatBuddy Desktop — Windows PC format companion with macOS report preview.",
  "author": {
    "name": "FormatBuddy",
    "email": "support@formatbuddy.app"
  },
  "license": "UNLICENSED",
  "main": "out/main/index.js",
  "scripts": {
    "embed-ps-hash": "node scripts/embed-ps-hash.mjs",
    "dev": "npm run embed-ps-hash && electron-vite dev",
    "prebuild": "npm run embed-ps-hash",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "lint": "eslint .",
    "test": "npm run embed-ps-hash && vitest run",
    "test:watch": "vitest",
    "predist:win": "npm run embed-ps-hash",
    "dist:win": "electron-vite build && electron-builder --win --publish never",
    "dist:mac": "npm run embed-ps-hash && electron-vite build && electron-builder --mac --publish never"
  },
  "dependencies": {
    "@electron-toolkit/preload": "3.0.1",
    "@electron-toolkit/utils": "3.0.0",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.0.6",
    "@testing-library/react": "16.1.0",
    "@types/node": "22.10.5",
    "@types/react": "19.0.7",
    "@types/react-dom": "19.0.3",
    "@typescript-eslint/eslint-plugin": "8.20.0",
    "@typescript-eslint/parser": "8.20.0",
    "@vitejs/plugin-react": "4.3.4",
    "electron": "33.3.1",
    "electron-builder": "25.1.8",
    "electron-vite": "2.3.0",
    "eslint": "9.18.0",
    "eslint-plugin-react": "7.37.4",
    "eslint-plugin-react-hooks": "5.1.0",
    "jsdom": "26.0.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "tailwindcss": "4.0.6",
    "typescript": "5.7.3",
    "vite": "5.4.11",
    "vitest": "2.1.8"
  }
}
